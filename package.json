{
  "name": "@tokenrip/cli",
  "version": "1.0.1",
  "description": "CLI and library for AI agents to create and share assets via Tokenrip",
  "type": "module",
  "main": "dist/cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tokenrip": "dist/cli.js"
  },
  "files": [
    "dist",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "commander": "^12.1.0",
    "form-data": "^4.0.1",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "license": "MIT"
}
